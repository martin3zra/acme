APP_NAME=
APP_KEY=
APP_ENV=dev
APP_PORT=8080
APP_URL="http://localhost:${APP_PORT}"
VITE_APP_URL="${APP_URL}"

# Port the import event-stream listener binds.
SSE_PORT=8090
# Absolute base URL the browser dials for the event stream. Leave empty to
# derive it from APP_URL's scheme and host with SSE_PORT substituted. Set it
# explicitly when a reverse proxy terminates the stream on another host.
SSE_URL=

# debug|info|warn|error
LOG_LEVEL=info
# text|json — defaults to json when APP_ENV=prod, text otherwise.
LOG_FORMAT=

DB_NAME=
DB_USERNAME=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=
DB_SSLMODE=disable

SESSION_LIFETIME=120

MAIL_DRIVER=smtp|api
MAIL_HOST=http://localhost
MAIL_PORT=1025
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl

SCHEDULER_INTERVAL=